{
  "expo": {
    "name": "Atlas",
    "slug": "gym-tracker",
    "scheme": "gymtracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0B0C",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.neiltapita.gymtracker",
      "icon": {
        "light": "./assets/icon-light.png",
        "dark": "./assets/icon-dark.png",
        "tinted": "./assets/icon-tinted.png"
      }
    },
    "android": {
      "package": "com.neiltapita.gymtracker",
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0C",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "permissions": [
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Atlas to access your photos to log a meal from a picture.",
          "cameraPermission": "Allow Atlas to use your camera to snap a photo of your meal for automatic macro estimation."
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
